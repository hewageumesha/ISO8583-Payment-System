<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F111A"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/bannerHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#161925"
        android:paddingVertical="18dp"
        android:paddingHorizontal="20dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Payment - App"
            android:textSize="22sp"
            android:textColor="#00E5FF"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_gravity="center_horizontal"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/bannerHeader"
        android:layout_above="@+id/bottomActionLayout"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="15dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CARD NUMBER (PAN)"
                android:textColor="#A0AABF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>
            <EditText
                android:id="@+id/etCardNo"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="5365612345731002"
                android:textColor="#FFFFFF"
                android:textColorHint="#4E5668"
                android:background="#161925"
                android:inputType="number"
                android:maxLength="16"
                android:textSize="14sp"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRANSACTION AMOUNT"
                android:textColor="#A0AABF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>
            <EditText
                android:id="@+id/etAmount"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="1000"
                android:textColor="#FFFFFF"
                android:textColorHint="#4E5668"
                android:background="#161925"
                android:inputType="number"
                android:textSize="14sp"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EXPIRY DATE"
                        android:textColor="#A0AABF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp"/>
                    <EditText
                        android:id="@+id/etExpiry"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:hint="2812"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#4E5668"
                        android:background="#161925"
                        android:inputType="number"
                        android:maxLength="4"
                        android:textSize="14sp"
                        android:paddingHorizontal="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SECURITY CODE (CVV)"
                        android:textColor="#A0AABF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp"/>
                    <EditText
                        android:id="@+id/etCVV"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:hint="123"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#4E5668"
                        android:background="#161925"
                        android:inputType="numberPassword"
                        android:maxLength="3"
                        android:textSize="14sp"
                        android:paddingHorizontal="12dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TARGET INVOICE NUMBER (FOR VOIDS)"
                android:textColor="#FFB74D"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>
            <EditText
                android:id="@+id/etInvoiceNo"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="000001"
                android:textColor="#FFFFFF"
                android:textColorHint="#5D4037"
                android:background="#231F20"
                android:inputType="number"
                android:textSize="14sp"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvLogTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE SYSTEM NETWORK CONSOLE MTI LOGS:"
                android:textColor="#00E5FF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"
                android:letterSpacing="0.05"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#161925"
                android:padding="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSystemLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="System Initializing...\nSwitch Engine online, bound internally to port 5000."
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:textColor="#A0FFB4"
                    android:lineSpacingMultiplier="1.2"
                    android:textIsSelectable="true"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomActionLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="15dp"
        android:orientation="vertical"
        android:background="#0F111A"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnFireSale"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:text="SALE"
                android:backgroundTint="#007ACC"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:elevation="2dp"/>

            <Button
                android:id="@+id/btnVoidSale"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:text="VOID SALE"
                android:backgroundTint="#D32F2F"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:elevation="2dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnSettlement"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="SETTLE BATCH RECONCILIATION"
            android:backgroundTint="#8E24AA"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:elevation="2dp"/>
    </LinearLayout>

</RelativeLayout>